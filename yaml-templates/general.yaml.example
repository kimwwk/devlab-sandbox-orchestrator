# ============================================================
# DevLab Project Config — Reference for Forge
# ============================================================
# Forge: use this as a template when creating YAML configs
# for dispatching Claude Code agents via `devlab run`.
#
# Required fields: name, repo, and one of (linear_issue | task)
# Everything else has sensible defaults.
# ============================================================

# --- Required ---

# Project identifier (used for container naming: devlab-<name>)
name: our-pot-app

# Git repository URL (must be cloneable; private repos need GITHUB_TOKEN in .env)
repo: https://github.com/kimwwk/our-pot-app.git

# --- Task Source (pick one) ---

# Option A: Linear issue — agent fetches issue, does work, posts comment, updates status
linear_issue: "OUR-123"

# Option B: Literal task — agent receives this text as its prompt
# task: |
#   Describe what the agent should do here.
#   Can be multi-line.

# --- Agent Role ---
# Available: developer, qa, reviewer, analyst
# - developer: full access + browser, clones product repo, ships PRs (default)
# - qa: full access + browser, clones dedicated test repo, runs tests against deployed URL
# - reviewer: read-only, provides code review feedback
# - analyst: full access, no browser — research and analysis tasks
agent: developer

# --- Optional Overrides ---

# Model: haiku, sonnet, opus (default: agent's default, usually sonnet)
model: sonnet

# Toolchain: node, python, fullstack (default: node)
# Determines which Docker image to use
toolchain: node

# Host port mapped to container's 8080 (default: 8888)
# Access VNC at http://localhost:<port>/vnc/index.html
# Access VSCode at http://localhost:<port>/code-server/
port: 8888

# Timeout in seconds (default: 600)
timeout: 600

# --- Setup Command ---
# Shell command to run after cloning the repo, before the agent starts.
# Use for dependency installation, build steps, browser setup, etc.
# setup_command: npm install
# setup_command: npm install && npx playwright install --with-deps chromium
# setup_command: uv sync

# --- Project Environment ---
# Key-value pairs written as .env file in the project root inside the container.
# Separate from system env (ANTHROPIC_API_KEY, GITHUB_TOKEN) which are injected
# at the container level via docker run -e.
# project_env:
#   BASE_URL: https://my-app.vercel.app          # QA: deployed link for tests
#   DATABASE_URL: postgres://localhost:5432/mydb  # Dev: database connection
#   NEXT_PUBLIC_API_KEY: sk-xxx                   # Dev: app config

# --- Notification ---
# Webhook called when task completes
notify:
  webhook: http://192.168.101.130:5678/webhook/devlab-task-done
  channels:
    - telegram
    - slack
  # Who triggered this dispatch (default: Forge)
  # n8n routes Slack messages to different channels based on this value
  triggered_by: Forge

# --- MCP Servers ---
# Override or extend the agent's default MCP servers.
# Linear MCP is required when using linear_issue.
mcp_servers:
  linear:
    command: "npx"
    args: ["-y", "mcp-remote", "https://mcp.linear.app/mcp", "--header", "Authorization:${AUTH_HEADER}"]
    env:
      AUTH_HEADER: "Bearer YOUR_LINEAR_API_KEY_HERE"
