name: our-pot-app-qa
repo: https://github.com/kimwwk/our-pot-qa.git
toolchain: node
agent: qa

linear_issue: "OUR-90"

model: sonnet
port: 8888
timeout: 300

project_env:
  BASE_URL: https://our-pot-app-git-develop-kimwongwwk-gmailcoms-projects.vercel.app

notify:
  webhook: http://192.168.101.130:5678/webhook/devlab-task-done
  channels:
    - slack

mcp_servers:
  linear:
    command: "npx"
    args: ["-y", "mcp-remote", "https://mcp.linear.app/mcp", "--header", "Authorization:${AUTH_HEADER}"]
    env:
      AUTH_HEADER: "Bearer YOUR_LINEAR_API_KEY_HERE"
